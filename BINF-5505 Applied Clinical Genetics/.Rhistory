meta <- as.data.frame(colData(airway))
head(counts[, 1:4])
meta
dim(counts)
dim(counts)
colnames(counts)
rownames(meta)
all(colnames(counts) == rownames(meta))
meta[, c("cell", "dex")]
table(meta$dex)
table(meta$cell)

library(car)
library(ggplot2)
library(viridis)
library(RColorBrewer)
library(tidyverse)
# Add any additional packages/ libraries you may need here:
head(Migration)
# Plot 3d here
ggplot(data = Migration, aes(x = pops66, y = migrants)) +
geom_point(aes(colour = destination))+
geom_smooth(method = "glm",
method.args = list(family = "poisson"))
surveys %>%
drop_na() %>%
group_by(plot_id, sex) %>%
summarize(count = n(), # min, max, sd, n, mean, median
mean_hf = mean(hindfoot_length),
min_hf = min(hindfoot_length)) %>%
ggplot(aes(x = mean_hf, y = count, colour = sex)) +
geom_point(alpha = 0.1) +
geom_smooth(method = "glm", method.args = list(family = "poisson"),
se = FALSE, linetype = "dotdash") +
geom_smooth(method = "lm", se = FALSE, linetype = "dotted") +
geom_vline(aes(xintercept = 25),
colour = "coral",
linetype = "dotted") +
theme_classic()
# Plot 3d here
ggplot(data = Migration, aes(x = pops66, y = migrants, colour = destination)) +
geom_point()+
geom_smooth(method = "glm",
method.args = list(family = "poisson"))
# Plot 2d here
